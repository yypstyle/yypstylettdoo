{
  "name": "报关初稿生成器",
  "short_name": "报关生成器",
  "description": "装车单自动匹配报关产品，生成Excel初稿和微信消息",
  "start_url": "./11.html",
  "display": "minimal-ui",
  "display_override": ["minimal-ui","standalone"],
  "orientation": "portrait",
  "background_color": "#080c14",
  "theme_color": "#00d4ff",
  "launch_handler": {"client_mode": "auto"},
  "share_target": {
    "action": "./11.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [{"name": "file", "accept": ["application/vnd.openxmlformats-officedocument.spreadsheetml.sheet","application/vnd.ms-excel","image/*","application/json"]}]
    }
  },
  "file_handlers": [
    {
      "action": "./11.html",
      "accept": {
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [".xlsx"],
        "application/vnd.ms-excel": [".xls"],
        "image/*": [".jpg",".jpeg",".png"],
        "application/json": [".json"]
      }
    }
  ],
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
